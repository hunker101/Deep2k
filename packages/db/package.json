{
  "name": "@deep2k/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"no tests in @deep2k/db\"",
    "lint": "echo \"no lint in @deep2k/db\"",
    "db:migrate": "tsx --env-file=../../.env src/migrate.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@deep2k/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2"
  }
}
